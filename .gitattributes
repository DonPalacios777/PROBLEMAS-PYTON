# EJERCICIO 10 - Sistema de pago de trabajadores
# -----------------------------------------------

historial_pagos = []

def calcular_pago_normal(horas_normales, pago_por_hora):
    # Pago basico: simplemente horas trabajadas por el valor de la hora.
    return horas_normales * pago_por_hora

def calcular_pago_extra(horas_extras, pago_por_hora):
    # La hora extra tiene un recargo del 50% sobre la hora normal (factor 1.5).
    # Esto es un criterio laboral comun para incentivar el trabajo en tiempo extra.
    pago_hora_extra = pago_por_hora * 1.5
    return horas_extras * pago_hora_extra

def calcular_bonificacion_hijos(numero_hijos, pago_por_hora):
    # Bonificacion familiar: por cada hijo se suma medio valor de la hora normal.
    # Es un beneficio adicional que depende del salario base del trabajador.
    return numero_hijos * 0.5 * pago_por_hora

def calcular_pago_total(horas_normales, pago_por_hora, horas_extras, numero_hijos):
    # Funcion coordinadora que llama a las tres funciones de calculo y las suma.
    # Retorna los cuatro valores por separado para poder mostrar el desglose en pantalla.
    pago_normal    = calcular_pago_normal(horas_normales, pago_por_hora)
    pago_extra     = calcular_pago_extra(horas_extras, pago_por_hora)
    bonificacion   = calcular_bonificacion_hijos(numero_hijos, pago_por_hora)
    total          = pago_normal + pago_extra + bonificacion
    return pago_normal, pago_extra, bonificacion, total  # Retorna una tupla con 4 valores

def registrar_pago(entrada_nom, entrada_hn, entrada_ph, entrada_he, entrada_hijos, etiqueta_res):
    nombre      = entrada_nom.get().strip()
    texto_hn    = entrada_hn.get().strip()
    texto_ph    = entrada_ph.get().strip()
    texto_he    = entrada_he.get().strip()
    texto_hijos = entrada_hijos.get().strip()

    # Verificacion de que ninguno de los 5 campos este vacio.
    if nombre == "" or texto_hn == "" or texto_ph == "" or texto_he == "" or texto_hijos == "":
        messagebox.showwarning("Aviso", "Por favor completa todos los campos.")
        return

    # Cada campo se convierte y valida por separado para dar mensajes de error especificos.
    try:
        horas_normales = int(texto_hn)
    except ValueError:
        messagebox.showerror("Error", "Las horas normales deben ser un numero entero.")
        return

    if horas_normales < 0:
        messagebox.showerror("Error", "Las horas normales no pueden ser negativas.")
        return

    try:
        pago_por_hora = float(texto_ph)
    except ValueError:
        messagebox.showerror("Error", "El pago por hora debe ser un numero. Ejemplo: 15.50")
        return

    if pago_por_hora <= 0:
        messagebox.showerror("Error", "El pago por hora debe ser mayor que 0.")
        return

    try:
        horas_extras = int(texto_he)
    except ValueError:
        messagebox.showerror("Error", "Las horas extras deben ser un numero entero.")
        return

    if horas_extras < 0:
        messagebox.showerror("Error", "Las horas extras no pueden ser negativas.")
        return

    try:
        numero_hijos = int(texto_hijos)
    except ValueError:
        messagebox.showerror("Error", "El numero de hijos debe ser un numero entero.")
        return

    if numero_hijos < 0:
        messagebox.showerror("Error", "El numero de hijos no puede ser negativo.")
        return

    # Desempaquetamos la tupla que retorna calcular_pago_total en 4 variables distintas.
    pago_normal, pago_extra, bonificacion, total = calcular_pago_total(
        horas_normales, pago_por_hora, horas_extras, numero_hijos
    )

    historial_pagos.append({
        "nombre":      nombre,
        "pago_normal": pago_normal,
        "pago_extra":  pago_extra,
        "bonificacion": bonificacion,
        "total":       total
    })

    etiqueta_res.config(
        text=(
            "Trabajador    : " + nombre + "\n"
            "Pago normal   : S/ " + str(round(pago_normal, 2)) + "\n"
            "Pago extras   : S/ " + str(round(pago_extra, 2)) + "\n"
            "Bonificacion  : S/ " + str(round(bonificacion, 2)) + "\n"
            "Total a pagar : S/ " + str(round(total, 2))
        )
    )

    entrada_nom.delete(0, tk.END)
    entrada_hn.delete(0, tk.END)
    entrada_ph.delete(0, tk.END)
    entrada_he.delete(0, tk.END)
    entrada_hijos.delete(0, tk.END)
    entrada_nom.focus()

