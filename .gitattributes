def numero_en_rango(numero):
    # Funcion reutilizable que verifica si el numero esta estrictamente entre 0 y 20.
    # "Estrictamente" significa que 0 y 20 no son validos, solo los numeros entre ellos.
    # Esta funcion se usa tanto en el ejercicio 5 como en el 6.
    if numero > 0 and numero < 20:
        return True
    else:
        return False

