# tk.Tk() crea la ventana raiz del programa. Solo puede existir una.
# Todas las demas ventanas son Toplevel() que dependen de esta.
ventana_principal = tk.Tk()
ventana_principal.title("Menu Principal - Ejercicios Python")

tk.Label(ventana_principal, text="Menu Principal", font=("Arial", 16, "bold")).pack(pady=15)
tk.Label(ventana_principal, text="Selecciona un ejercicio:", fg="gray").pack()

# Lista de tuplas: cada tupla contiene el texto del boton y la funcion que debe ejecutar.
# Esto evita escribir 10 bloques de tk.Button por separado, es mas organizado.
ejercicios = [
    ("Ejercicio 1 - Sistema de aumento de sueldos",    abrir_ejercicio1),
    ("Ejercicio 2 - Pago en parque de diversiones",    abrir_ejercicio2),
    ("Ejercicio 3 - Descuentos por mes en tienda",     abrir_ejercicio3),
    ("Ejercicio 4 - Validacion numero menor que 10",   abrir_ejercicio4),
    ("Ejercicio 5 - Validacion numero en rango 0-20",  abrir_ejercicio5),
    ("Ejercicio 6 - Registro de intentos",             abrir_ejercicio6),
    ("Ejercicio 7 - Suma de primeros N enteros",       abrir_ejercicio7),
    ("Ejercicio 8 - Suma acumulativa",                 abrir_ejercicio8),
    ("Ejercicio 9 - Suma hasta superar limite",        abrir_ejercicio9),
    ("Ejercicio 10 - Sistema de pago de trabajadores", abrir_ejercicio10),
]

# Recorremos la lista y creamos un boton por cada ejercicio dinamicamente.
# "nombre" es el texto del boton y "funcion" es lo que se ejecuta al presionarlo.
for nombre, funcion in ejercicios:
    tk.Button(
        ventana_principal,
        text=nombre,
        width=45,
        anchor="w",     # El texto del boton se alinea a la izquierda dentro del boton
        command=funcion
    ).pack(padx=20, pady=3)

tk.Label(ventana_principal, text="").pack()  # Espacio visual vacio al final

tk.Button(
    ventana_principal,
    text="Salir",
    width=45,
    command=ventana_principal.destroy  # Cierra la ventana principal y termina el programa
).pack(padx=20, pady=(0, 20))

# mainloop() es el bucle principal del programa.
# Mantiene la ventana abierta y escucha eventos (clics, teclas, etc.) hasta que se cierre.
ventana_principal.mainloop()
