def abrir_ejercicio4():
    ventana = tk.Toplevel()
    ventana.title("Ejercicio 4 - Validacion numero menor que 10")

    # Usamos una lista con un solo elemento [0] en lugar de una variable simple.
    # Esto es necesario porque las funciones internas (como validar_numero) no pueden
    # modificar variables locales del nivel superior directamente, pero si pueden
    # modificar el contenido de una lista. Es un truco comun en tkinter con funciones anidadas.
    intentos = [0]

    tk.Label(ventana, text="Validacion: numero menor que 10", font=("Arial", 13, "bold")).pack(pady=10)
    tk.Label(ventana, text="Ingresa un numero entero menor que 10:").pack()

    entrada_num = tk.Entry(ventana, width=20)
    entrada_num.pack(pady=5)

    etiqueta_res = tk.Label(ventana, text="", width=40, height=4, justify="left", anchor="nw", padx=8, pady=5)
    etiqueta_res.pack(padx=15, pady=8)

    etiqueta_intentos = tk.Label(ventana, text="Intentos realizados: 0", fg="gray")
    etiqueta_intentos.pack()

    # Funcion interna (anidada): se define dentro de abrir_ejercicio4 y puede
