# EJERCICIO 1 - Sistema de aumento de sueldos
# -----------------------------------------------

# Lista global donde vamos guardando cada trabajador que se registre.
# Al ser global, cualquier funcion del programa puede acceder a ella.
historial_sueldos = []

def calcular_porcentaje_sueldo(sueldo):
    # Segun el sueldo que tenga el trabajador, se le asigna un porcentaje de aumento diferente.
    # Esto es una estructura condicional encadenada (if / elif / else).
    # Retorna un decimal: 0.15 = 15%, 0.10 = 10%, 0.08 = 8%
    if sueldo < 4000:
        return 0.15         # Sueldos bajos reciben el mayor aumento
    elif sueldo <= 7000:
        return 0.10         # Sueldos medios reciben un aumento moderado
    else:
        return 0.08         # Sueldos altos reciben el menor aumento

def registrar_trabajador(entrada_nom, entrada_sue, etiqueta_res):
    # Esta funcion recibe como parametros los campos de texto de la ventana
    # y la etiqueta donde se mostrara el resultado.

    # .get() extrae el texto que el usuario escribio en el campo.
    # .strip() elimina espacios en blanco al inicio y al final del texto.
    nombre = entrada_nom.get().strip()
    texto_sueldo = entrada_sue.get().strip()

    # Verificamos que ninguno de los campos este vacio antes de continuar.
    if nombre == "" or texto_sueldo == "":
        messagebox.showwarning("Aviso", "Por favor completa todos los campos.")
        return  # Cortamos la ejecucion de la funcion aqui si faltan datos.

    # Intentamos convertir el texto del sueldo a numero decimal (float).
    # Si el usuario escribio letras, el try/except atrapa el error sin que el programa explote.
    try:
        sueldo = float(texto_sueldo)
    except ValueError:
        # ValueError ocurre cuando intentas convertir algo que no es numero, ej: "abc"
        messagebox.showerror("Error", "El sueldo debe ser un numero. Ejemplo: 3500")
        return

    # Validamos que el sueldo sea un valor positivo con sentido.
    if sueldo <= 0:
        messagebox.showerror("Error", "El sueldo debe ser mayor que 0.")
        return

    # Calculamos el aumento llamando a la funcion que definimos arriba.
    porcentaje = calcular_porcentaje_sueldo(sueldo)
    aumento = sueldo * porcentaje          # Monto en soles del aumento
    nuevo_sueldo = sueldo + aumento        # Sueldo original + el aumento calculado

    # Guardamos los datos del trabajador como un diccionario dentro de la lista global.
    # Un diccionario almacena pares clave:valor, similar a una ficha de datos.
    historial_sueldos.append({
        "nombre": nombre,
        "sueldo_base": sueldo,
        "sueldo_nuevo": nuevo_sueldo
    })

    # Actualizamos el texto de la etiqueta en la ventana con el resumen del calculo.
    # round(x, 2) redondea el numero a 2 decimales para mostrar soles con centimos.
    # int(porcentaje * 100) convierte 0.15 -> 15 para mostrarlo como porcentaje entero.
    etiqueta_res.config(
        text=(
            "Trabajador: " + nombre + "\n"
            "Sueldo base: S/ " + str(round(sueldo, 2)) + "\n"
            "Porcentaje de aumento: " + str(int(porcentaje * 100)) + "%\n"
            "Nuevo sueldo: S/ " + str(round(nuevo_sueldo, 2))
        )
    )

    # Limpiamos los campos de texto para que el usuario pueda ingresar otro trabajador.
    entrada_nom.delete(0, tk.END)   # Borra desde el caracter 0 hasta el final
    entrada_sue.delete(0, tk.END)
    entrada_nom.focus()             # Mueve el cursor al campo de nombre automaticamente

def ver_historial_sueldos():
    # Si la lista esta vacia, no tiene sentido abrir la ventana de historial.
    if len(historial_sueldos) == 0:
        messagebox.showinfo("Aviso", "No hay trabajadores registrados todavia.")
        return

    # Toplevel() crea una ventana secundaria encima de la principal, sin cerrarla.
    ventana_h = tk.Toplevel()
    ventana_h.title("Historial de trabajadores")

    tk.Label(ventana_h, text="Historial de trabajadores", font=("Arial", 12, "bold")).pack(pady=10)

    # Scrollbar es la barra de desplazamiento vertical para cuando hay muchos registros.
    barra = tk.Scrollbar(ventana_h)
    barra.pack(side=tk.RIGHT, fill=tk.Y)  # La colocamos a la derecha y que ocupe toda la altura

    # Text es un widget que permite mostrar texto en varias lineas con scroll.
    # yscrollcommand conecta el area de texto con la barra de desplazamiento.
    area = tk.Text(ventana_h, width=45, height=15, yscrollcommand=barra.set)
    area.pack(padx=10, pady=5)
    barra.config(command=area.yview)  # Cuando mueves la barra, el texto se desplaza

    # enumerate(lista, 1) recorre la lista y nos da el indice empezando desde 1.
    for i, t in enumerate(historial_sueldos, 1):
        # insert(tk.END, texto) agrega texto al final del area de texto.
        area.insert(tk.END,
            str(i) + ". " + t["nombre"] + "\n"
            "   Sueldo base: S/ " + str(round(t["sueldo_base"], 2)) + "\n"
            "   Sueldo nuevo: S/ " + str(round(t["sueldo_nuevo"], 2)) + "\n"
            "   --------------------\n"
        )

    # Desactivamos el area de texto para que el usuario no pueda modificar lo que se muestra.
    area.config(state=tk.DISABLED)
    tk.Button(ventana_h, text="Cerrar", command=ventana_h.destroy).pack(pady=8)

def abrir_ejercicio1():
    # Cada ejercicio abre su propia ventana secundaria con Toplevel.
    ventana = tk.Toplevel()
    ventana.title("Ejercicio 1 - Aumento de sueldos")

    # grid() organiza los widgets en una cuadricula de filas y columnas.
    # columnspan=2 hace que el widget ocupe 2 columnas en lugar de 1.
    tk.Label(ventana, text="Sistema de aumento de sueldos", font=("Arial", 13, "bold")).grid(row=0, column=0, columnspan=2, pady=10)

    tk.Label(ventana, text="Nombre del trabajador:").grid(row=1, column=0, sticky="w", padx=15, pady=5)
    # sticky="w" alinea el widget al lado oeste (izquierda) de su celda
