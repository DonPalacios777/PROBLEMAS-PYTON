# EJERCICIO 2 - Pago en parque de diversiones
# -----------------------------------------------

historial_parque = []
COSTO_JUEGO = 50  # Constante con el precio fijo por juego. En mayusculas por convencion de Python.

def calcular_descuento_parque(edad):
    # Determina el porcentaje de descuento segun la edad del visitante.
    if edad < 10:
        return 0.25     # Ninos menores de 10: 25% de descuento
    elif edad <= 17:
        return 0.10     # Adolescentes hasta 17: 10% de descuento
    else:
        return 0.00     # Adultos: sin descuento

def registrar_visitante(entrada_nom, entrada_edad, entrada_juegos, etiqueta_res, etiqueta_rec):
    nombre = entrada_nom.get().strip()
    texto_edad = entrada_edad.get().strip()
    texto_juegos = entrada_juegos.get().strip()

    if nombre == "" or texto_edad == "" or texto_juegos == "":
        messagebox.showwarning("Aviso", "Por favor completa todos los campos.")
        return

    # La edad debe ser entero (int), no admitimos decimales como 12.5
    try:
        edad = int(texto_edad)
    except ValueError:
        messagebox.showerror("Error", "La edad debe ser un numero entero. Ejemplo: 12")
        return

    if edad <= 0:
        messagebox.showerror("Error", "La edad debe ser mayor que 0.")
        return

    try:
        juegos = int(texto_juegos)
    except ValueError:
        messagebox.showerror("Error", "La cantidad de juegos debe ser un numero entero.")
        return

    if juegos <= 0:
        messagebox.showerror("Error", "La cantidad de juegos debe ser mayor que 0.")
        return

    # Calculamos primero el costo sin descuento y luego aplicamos el porcentaje correspondiente.
    total_sin_descuento = juegos * COSTO_JUEGO
    descuento = calcular_descuento_parque(edad)
    total_final = total_sin_descuento - total_sin_descuento * descuento  # Precio con descuento aplicado

    historial_parque.append({
        "nombre": nombre,
        "edad": edad,
        "juegos": juegos,
        "total": total_final
    })

    # Preparamos el texto del descuento segun si aplica o no.
    if descuento > 0:
        desc_texto = "Descuento: " + str(int(descuento * 100)) + "%"
    else:
        desc_texto = "Descuento: sin descuento"

    etiqueta_res.config(
        text=(
            "Visitante: " + nombre + "  (edad: " + str(edad) + ")\n"
            "Juegos: " + str(juegos) + " x S/ " + str(COSTO_JUEGO) + " = S/ " + str(total_sin_descuento) + "\n"
            + desc_texto + "\n"
            "Total a pagar: S/ " + str(round(total_final, 2))
        )
    )

    # sum() recorre toda la lista y suma el campo "total" de cada visitante registrado.
    # Esto nos da el acumulado total que ha recaudado el parque en la sesion actual.
    total_recaudado = sum(v["total"] for v in historial_parque)
    etiqueta_rec.config(text="Total recaudado por el parque: S/ " + str(round(total_recaudado, 2)))

    entrada_nom.delete(0, tk.END)
    entrada_edad.delete(0, tk.END)
    entrada_juegos.delete(0, tk.END)
    entrada_nom.focus()

def ver_historial_parque():
    if len(historial_parque) == 0:
        messagebox.showinfo("Aviso", "No hay visitantes registrados todavia.")
        return

    ventana_h = tk.Toplevel()
    ventana_h.title("Historial de visitantes")

    tk.Label(ventana_h, text="Historial de visitantes", font=("Arial", 12, "bold")).pack(pady=10)

    barra = tk.Scrollbar(ventana_h)
    barra.pack(side=tk.RIGHT, fill=tk.Y)

    area = tk.Text(ventana_h, width=45, height=15, yscrollcommand=barra.set)
    area.pack(padx=10, pady=5)
    barra.config(command=area.yview)

    # Acumulamos el total recaudado recorriendo el historial con un contador manual.
    total_recaudado = 0
    for i, v in enumerate(historial_parque, 1):
        total_recaudado += v["total"]   # += es equivalente a total_recaudado = total_recaudado + v["total"]
        area.insert(tk.END,
            str(i) + ". " + v["nombre"] + "  (edad: " + str(v["edad"]) + ")\n"
            "   Juegos: " + str(v["juegos"]) + "\n"
            "   Total pagado: S/ " + str(round(v["total"], 2)) + "\n"
            "   --------------------\n"
        )

    area.insert(tk.END, "\nTotal recaudado: S/ " + str(round(total_recaudado, 2)) + "\n")
    area.config(state=tk.DISABLED)
    tk.Button(ventana_h, text="Cerrar", command=ventana_h.destroy).pack(pady=8)

