# -----------------------------------------------

historial_tienda = []

def calcular_descuento_tienda(numero_mes):
    # Convertimos el numero del mes (1-12) a su nombre en texto usando una lista como indice.
    # La lista empieza en indice 0, entonces restamos 1 al numero del mes para obtener la posicion correcta.
    nombres = ["Enero","Febrero","Marzo","Abril","Mayo","Junio",
               "Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"]
    nombre_mes = nombres[numero_mes - 1]  # Ej: mes 7 -> indice 6 -> "Julio"

    # Solo ciertos meses tienen promocion. El resto retorna 0.00 (sin descuento).
    if numero_mes == 7:
        return nombre_mes, 0.10   # Julio: 10% (campanas escolares)
    elif numero_mes == 10:
        return nombre_mes, 0.15   # Octubre: 15%
    elif numero_mes == 12:
        return nombre_mes, 0.20   # Diciembre: 20% (navidad)
    else:
        return nombre_mes, 0.00   # Retorna una tupla con dos valores: nombre y porcentaje

def registrar_compra(entrada_nom, entrada_mes, entrada_importe, etiqueta_res, etiqueta_total):
    nombre = entrada_nom.get().strip()
    texto_mes = entrada_mes.get().strip()
    texto_importe = entrada_importe.get().strip()

    if nombre == "" or texto_mes == "" or texto_importe == "":
        messagebox.showwarning("Aviso", "Por favor completa todos los campos.")
        return

    try:
        numero_mes = int(texto_mes)
    except ValueError:
        messagebox.showerror("Error", "El mes debe ser un numero del 1 al 12.")
        return

    # Validamos que el numero ingresado sea un mes valido dentro del rango 1-12.
    if numero_mes < 1 or numero_mes > 12:
        messagebox.showerror("Error", "El mes debe estar entre 1 y 12.")
        return

    try:
        importe = float(texto_importe)
    except ValueError:
        messagebox.showerror("Error", "El importe debe ser un numero. Ejemplo: 250")
        return

    if importe <= 0:
        messagebox.showerror("Error", "El importe debe ser mayor que 0.")
        return

    # La funcion retorna dos valores a la vez (tupla), los desempaquetamos en dos variables.
    nombre_mes, descuento = calcular_descuento_tienda(numero_mes)
    monto_descuento = importe * descuento       # Cuanto dinero se descuenta
    total = importe - monto_descuento           # Lo que realmente paga el cliente

    historial_tienda.append({
        "nombre": nombre,
        "mes": nombre_mes,
        "importe": importe,
        "descuento": int(descuento * 100),  # Guardamos el porcentaje como entero (ej: 20, no 0.20)
        "total": total
    })

    if descuento > 0:
        desc_texto = "Descuento: " + str(int(descuento * 100)) + "% (-S/ " + str(round(monto_descuento, 2)) + ")"
    else:
        desc_texto = "Descuento: sin promocion este mes"

    etiqueta_res.config(
        text=(
            "Cliente: " + nombre + "\n"
            "Mes: " + nombre_mes + "\n"
            "Importe: S/ " + str(round(importe, 2)) + "\n"
            + desc_texto + "\n"
            "Total final: S/ " + str(round(total, 2))
        )
    )

    # Recalculamos el total del dia sumando todos los totales del historial desde cero.
    # Usamos una expresion generadora dentro de sum() para recorrer la lista en una sola linea.
    total_dia = sum(c["total"] for c in historial_tienda)
    etiqueta_total.config(text="Total vendido hoy: S/ " + str(round(total_dia, 2)))

    entrada_nom.delete(0, tk.END)
    entrada_mes.delete(0, tk.END)
    entrada_importe.delete(0, tk.END)
    entrada_nom.focus()

def ver_historial_tienda():
    if len(historial_tienda) == 0:
        messagebox.showinfo("Aviso", "No hay compras registradas todavia.")
        return

    ventana_h = tk.Toplevel()
    ventana_h.title("Historial de compras")

    tk.Label(ventana_h, text="Historial de compras", font=("Arial", 12, "bold")).pack(pady=10)

    barra = tk.Scrollbar(ventana_h)
    barra.pack(side=tk.RIGHT, fill=tk.Y)

    area = tk.Text(ventana_h, width=45, height=15, yscrollcommand=barra.set)
    area.pack(padx=10, pady=5)
    barra.config(command=area.yview)

    total_dia = 0
    for i, c in enumerate(historial_tienda, 1):
        total_dia += c["total"]
        area.insert(tk.END,
            str(i) + ". " + c["nombre"] + "  (" + c["mes"] + ")\n"
            "   Importe: S/ " + str(round(c["importe"], 2)) + "\n"
            "   Descuento: " + str(c["descuento"]) + "%\n"
            "   Total: S/ " + str(round(c["total"], 2)) + "\n"
            "   --------------------\n"
        )

    area.insert(tk.END, "\nTotal vendido hoy: S/ " + str(round(total_dia, 2)) + "\n")
    area.config(state=tk.DISABLED)
    tk.Button(ventana_h, text="Cerrar", command=ventana_h.destroy).pack(pady=8)

