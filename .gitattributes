def calcular_suma_n(n):
    # Suma todos los enteros desde 1 hasta n usando un ciclo for.
    # Ejemplo: si n=4, calcula 1+2+3+4 = 10
    suma = 0
    for i in range(1, n + 1):  # range(1, n+1) genera los numeros del 1 al n inclusive
        suma = suma + i
    return suma

def construir_secuencia(n):
    # Genera el texto visual de la suma: "1 + 2 + 3 + ... + n"
    # Primero construimos una lista con cada numero como texto, luego los unimos con " + ".
    partes = []
    for i in range(1, n + 1):
        partes.append(str(i))
    return " + ".join(partes)  # join() une todos los elementos de la lista con el separador indicado

def abrir_ejercicio7():
    ventana = tk.Toplevel()
    ventana.title("Ejercicio 7 - Suma de primeros N enteros")

    tk.Label(ventana, text="Suma de los primeros N enteros", font=("Arial", 13, "bold")).pack(pady=10)
    tk.Label(ventana, text="Ingresa un numero N positivo:").pack()

    entrada_n = tk.Entry(ventana, width=20)
    entrada_n.pack(pady=5)

    etiqueta_res = tk.Label(ventana, text="", width=45, height=3, justify="left", anchor="nw", padx=8, pady=5)
    etiqueta_res.pack(padx=15, pady=5)

    # Scrollbar horizontal para poder deslizar la secuencia si es muy larga.
    # orient="horizontal" cambia la orientacion por defecto (que es vertical).
    barra = tk.Scrollbar(ventana, orient="horizontal")
    barra.pack(fill=tk.X, padx=15)

    # wrap=tk.NONE evita que el texto salte de linea automaticamente,
    # forzando el uso del scroll horizontal para leer secuencias largas.
    area_secuencia = tk.Text(ventana, width=45, height=4, wrap=tk.NONE, xscrollcommand=barra.set)
    area_secuencia.pack(padx=15, pady=3)
    barra.config(command=area_secuencia.xview)  # Conectamos la barra con el desplazamiento horizontal

    def calcular():
        texto = entrada_n.get().strip()

        try:
            n = int(texto)
        except ValueError:
            messagebox.showerror("Error", "Debes ingresar un numero entero. Ejemplo: 5")
            return

        if n <= 0:
            messagebox.showerror("Error", "El numero N debe ser mayor que 0.")
            return

        suma = calcular_suma_n(n)
        secuencia = construir_secuencia(n)

        etiqueta_res.config(
            text="N = " + str(n) + "\n"
                 "Resultado: " + secuencia + " = " + str(suma)
        )

        # Habilitamos el area, la limpiamos, escribimos el nuevo resultado y la volvemos a deshabilitar.
        area_secuencia.config(state=tk.NORMAL)
        area_secuencia.delete("1.0", tk.END)   # "1.0" significa fila 1, columna 0 (inicio del texto)
        area_secuencia.insert(tk.END, secuencia + " = " + str(suma))
        area_secuencia.config(state=tk.DISABLED)

    tk.Button(ventana, text="Calcular", width=15, command=calcular).pack(pady=8)
    tk.Button(ventana, text="Regresar al menu", width=20, command=ventana.destroy).pack(pady=5)


